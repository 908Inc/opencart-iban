{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-payment" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fas fa-save"></i></button>
        <a href="{{ back }}" data-bs-toggle="tooltip" title="{{ button_back }}" class="btn btn-light"><i class="fas fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div class="card">
      <div class="card-header"><i class="fas fa-pencil-alt"></i> {{ text_edit }}</div>
      <div class="card-body">
        <form id="form-payment" action="{{ save }}" method="post" data-oc-toggle="ajax">
          <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item" role="presentation">
              <a class="nav-link active" id="tab-general-link" data-bs-toggle="tab" href="#tab-general" role="tab" aria-controls="tab-general" aria-selected="true">{{ tab_general }}</a>
            </li>
            <li class="nav-item" role="presentation">
              <a class="nav-link" id="tab-autoclient-link" data-bs-toggle="tab" href="#tab-autoclient" role="tab" aria-controls="tab-autoclient" aria-selected="false">{{ tab_autoclient }}</a>
            </li>
          </ul>
          <div class="tab-content pt-3">
            <div class="tab-pane fade show active" id="tab-general" role="tabpanel" aria-labelledby="tab-general-link">
              <div class="row mb-3">
                <label for="input-iban" class="col-sm-2 col-form-label">{{ entry_iban }}</label>
                <div class="col-sm-10">
                  <input type="text" name="payment_opencart_iban_iban" value="{{ payment_opencart_iban_iban|e }}" placeholder="{{ entry_iban }}" id="input-iban" class="form-control"/>
                  <div id="error-iban" class="invalid-feedback"></div>
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-code" class="col-sm-2 col-form-label">{{ entry_code }}</label>
                <div class="col-sm-10">
                  <input type="text" name="payment_opencart_iban_code" value="{{ payment_opencart_iban_code|e }}" placeholder="{{ entry_code }}" id="input-code" class="form-control"/>
                  <div id="error-code" class="invalid-feedback"></div>
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-x-client-key" class="col-sm-2 col-form-label">{{ entry_x_client_key }}</label>
                <div class="col-sm-10">
                  <input type="text" name="payment_opencart_iban_x_client_key" value="{{ payment_opencart_iban_x_client_key|e }}" placeholder="{{ entry_x_client_key }}" id="input-x-client-key" class="form-control"/>
                  <div class="form-text">{{ help_x_client_key }}</div>
                  <div id="error-x-client-key" class="invalid-feedback"></div>
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-x-client-name" class="col-sm-2 col-form-label">{{ entry_x_client_name }}</label>
                <div class="col-sm-10">
                  <input type="text" name="payment_opencart_iban_x_client_name" value="{{ payment_opencart_iban_x_client_name|e }}" placeholder="{{ entry_x_client_name }}" id="input-x-client-name" class="form-control"/>
                  <div class="form-text">{{ help_x_client_name }}</div>
                  <div id="error-x-client-name" class="invalid-feedback"></div>
                </div>
              </div>
              {% for language in languages %}
              <div class="row mb-3">
                <label for="input-purpose-{{ language.language_id }}" class="col-sm-2 col-form-label">{{ entry_purpose }}</label>
                <div class="col-sm-10">
                  <div class="input-group">
                    <span class="input-group-text"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}"/></span>
                    <input type="text" name="payment_opencart_iban_purpose_{{ language.language_id }}" value="{{ (payment_opencart_iban_purpose[language.language_id] ?? '')|e }}" placeholder="{{ entry_purpose }}" id="input-purpose-{{ language.language_id }}" class="form-control"/>
                  </div>
                  <div class="form-text">{{ help_purpose }}</div>
                </div>
              </div>
              {% endfor %}
              <div class="row mb-3">
                <label for="input-order-status" class="col-sm-2 col-form-label">{{ entry_order_status }}</label>
                <div class="col-sm-10">
                  <select name="payment_opencart_iban_order_status_id" id="input-order-status" class="form-select">
                    {% for order_status in order_statuses %}
                      <option value="{{ order_status.order_status_id }}"{% if order_status.order_status_id == payment_opencart_iban_order_status_id %} selected{% endif %}>{{ order_status.name }}</option>
                    {% endfor %}
                  </select>
                </div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label">{{ entry_status }}</label>
                <div class="col-sm-10">
                  <div class="form-check form-switch form-switch-lg">
                    <input type="hidden" name="payment_opencart_iban_status" value="0"/>
                    <input type="checkbox" name="payment_opencart_iban_status" value="1" id="input-status" class="form-check-input"{% if payment_opencart_iban_status %} checked{% endif %}/>
                  </div>
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-sort-order" class="col-sm-2 col-form-label">{{ entry_sort_order }}</label>
                <div class="col-sm-10">
                  <input type="text" name="payment_opencart_iban_sort_order" value="{{ payment_opencart_iban_sort_order|e }}" placeholder="{{ entry_sort_order }}" id="input-sort-order" class="form-control"/>
                </div>
              </div>
            </div>
            <div class="tab-pane fade" id="tab-autoclient" role="tabpanel" aria-labelledby="tab-autoclient-link">
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label">{{ entry_autoclient }}</label>
                <div class="col-sm-10">
                  <div class="form-check form-switch form-switch-lg">
                    <input type="hidden" name="payment_opencart_iban_autoclient" value="0"/>
                    <input type="checkbox" name="payment_opencart_iban_autoclient" value="1" id="input-autoclient" class="form-check-input"{% if payment_opencart_iban_autoclient %} checked{% endif %}/>
                  </div>
                  <div class="form-text">{{ help_autoclient }}</div>
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-paid-order-status" class="col-sm-2 col-form-label">{{ entry_paid_order_status }}</label>
                <div class="col-sm-10">
                  <select name="payment_opencart_iban_paid_order_status_id" id="input-paid-order-status" class="form-select">
                    {% for order_status in order_statuses %}
                      <option value="{{ order_status.order_status_id }}"{% if order_status.order_status_id == payment_opencart_iban_paid_order_status_id %} selected{% endif %}>{{ order_status.name }}</option>
                    {% endfor %}
                  </select>
                  <div class="form-text">{{ help_paid_order_status }}</div>
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-callback-url" class="col-sm-2 col-form-label">{{ entry_callback_url }}</label>
                <div class="col-sm-10">
                  <div class="input-group">
                    <input type="text" value="{{ callback_url }}" class="form-control" readonly id="input-callback-url"/>
                    <button class="btn btn-outline-secondary" type="button" onclick="navigator.clipboard.writeText(document.getElementById('input-callback-url').value)"><i class="fas fa-copy"></i></button>
                  </div>
                  <div class="form-text">{{ help_callback_url }}</div>
                </div>
              </div>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<script>
(function() {
  var panes = [
    { link: document.getElementById('tab-general-link'), pane: document.getElementById('tab-general') },
    { link: document.getElementById('tab-autoclient-link'), pane: document.getElementById('tab-autoclient') }
  ];

  new MutationObserver(function() {
    for (var i = 0; i < panes.length; i++) {
      if (panes[i].pane && panes[i].pane.querySelector('.is-invalid')) {
        bootstrap.Tab.getOrCreateInstance(panes[i].link).show();
        return;
      }
    }
  }).observe(document.getElementById('form-payment'), {
    subtree: true,
    attributes: true,
    attributeFilter: ['class']
  });
})();
</script>
{{ footer }}
